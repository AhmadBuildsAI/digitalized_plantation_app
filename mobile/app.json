{
  "expo": {
    "name": "Digitalized Plantation",
    "slug": "digitalized-plantation",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digitalizedplantation.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "com.digitalizedplantation.app"
    },
    "scheme": "digitalized-plantation",
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
