{
  "name": "digitalized-plantation",
  "version": "1.0.0",
  "private": true,
  "description": "Digitalized Plantation - Modern plantation management platform",
  "workspaces": [
    "packages/shared",
    "backend",
    "web",
    "mobile"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=@digitalized-plantation/backend",
    "dev:web": "npm run dev --workspace=@digitalized-plantation/web",
    "dev:mobile": "npm run start --workspace=@digitalized-plantation/mobile",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "npm run db:push --workspace=@digitalized-plantation/backend",
    "db:seed": "npm run db:seed --workspace=@digitalized-plantation/backend",
    "setup": "npm install && npm run db:up && copy backend\\.env.example backend\\.env && copy web\\.env.example web\\.env.local && npm run db:migrate && npm run db:seed"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
